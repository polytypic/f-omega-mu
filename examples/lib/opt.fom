include "types"
include "algebras"

let pure = Λα.λx:α.'Some x

let bind = Λα.Λβ.λxyO:α → opt β.case {
  None = λ().'None
  Some = λx:α.xyO x
}

let traverse = ΛF.λM:Monad F.Λα.Λβ.λxyM:α → F β.case {
  None = λ().
    M.pure[opt β] 'None
  Some = λx:α.
    xyM x ▷ M.bind[β][opt β] λy:β.
    M.pure[opt β] ◁ 'Some y
}

{pure, bind, traverse}
